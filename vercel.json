{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server/server.js" },
    { "src": "/socket.io/(.*)", "dest": "server/server.js" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ]
}
